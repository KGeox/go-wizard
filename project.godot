[layer_names]

2d_render/layer_1="player"
2d_render/layer_2="enemy"
2d_render/layer_3="items"
2d_render/layer_4="environment"
2d_physics/layer_1="player"
3d_physics/layer_1="everything_else"
2d_physics/layer_2="enemy"
3d_physics/layer_2="ground"
2d_physics/layer_3="items"
3d_physics/layer_3="coin"
2d_physics/layer_4="environment"
3d_physics/layer_4="enemy"
3d_physics/layer_5="fallzone"
3d_physics/layer_6="player"
3d_physics/layer_7="item"

[physics]

3d/physics_engine="Jolt Physics"
3d/default_gravity=14.0
common/physics_interpolation=true

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
